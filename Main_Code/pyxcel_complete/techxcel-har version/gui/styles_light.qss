/* =============================================
   PyXcel Premium Light Theme — styles_light.qss
   KiTE Development Team
   ============================================= */

/* ── Global ── */
* {
    font-family: "Segoe UI Variable", "Segoe UI", Arial, sans-serif;
    font-size: 13px;
    color: #213048;
}

QMainWindow, QWidget {
    background-color: #f3f6fb;
}

/* ── Sidebar Navigation ── */
#sidebar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff, stop:1 #edf2fa);
    border-right: 1px solid #d6dfec;
    min-width: 220px;
    max-width: 220px;
}

#sidebar QLabel#app_title {
    font-size: 18px;
    font-weight: bold;
    color: #2f79d6;
    padding: 20px 16px 4px 16px;
}

#sidebar QLabel#app_subtitle {
    font-size: 11px;
    color: #607188;
    padding: 0px 16px 20px 16px;
}

#sidebar QLabel#section_label {
    font-size: 10px;
    color: #607188;
    padding: 12px 16px 6px 16px;
    letter-spacing: 1px;
    text-transform: uppercase;
}

#sidebar QLabel#file_label,
#sidebar QLabel#ollama_indicator {
    color: #5f7088;
    font-size: 11px;
}

#sidebar QLabel#ollama_indicator[status="online"] {
    color: #21895d;
}

#sidebar QLabel#ollama_indicator[status="warning"] {
    color: #b87416;
}

#sidebar QLabel#ollama_indicator[status="offline"] {
    color: #d14646;
}

/* Sidebar nav buttons */
#nav_btn {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    text-align: left;
    color: #4e6077;
    font-size: 13px;
    margin: 2px 8px;
}

#nav_btn:hover {
    background-color: #e7eef9;
    color: #1c2f4b;
}

#nav_btn[active="true"] {
    background-color: #dce8f8;
    color: #256fc9;
    border-left: 3px solid #2f79d6;
}

/* ── Main Content Area ── */
#content_area {
    background: qradialgradient(cx:0.15, cy:0.05, radius:1.1,
        stop:0 #ffffff, stop:0.45 #f5f8fd, stop:1 #ecf1f9);
    padding: 30px;
}

/* ── Panel Titles ── */
QLabel#panel_title {
    font-size: 20px;
    font-weight: bold;
    color: #213048;
    margin-bottom: 4px;
}

QLabel#panel_subtitle {
    font-size: 12px;
    color: #6d7f95;
    margin-bottom: 20px;
}

/* ── Badge Labels ── */
QLabel#badge {
    background-color: #e7eef9;
    color: #2f79d6;
    border-radius: 12px;
    padding: 3px 12px;
    font-size: 11px;
    font-weight: bold;
}

/* ── Cards ── */
#card {
    background-color: #ffffff;
    border: 1px solid #d5deec;
    border-radius: 12px;
    padding: 20px;
}

#card:hover {
    border-color: #b9c9e1;
}

/* ── Input Fields ── */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #ffffff;
    border: 1px solid #cfd9ea;
    border-radius: 8px;
    padding: 8px 12px;
    color: #213048;
    selection-background-color: #a5c6ef;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #4d93e6;
}

QLineEdit::placeholder {
    color: #8797ac;
}

/* ── Buttons ── */
QPushButton {
    background-color: #2f79d6;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 9px 20px;
    font-size: 13px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #3f89e6;
}

QPushButton:pressed {
    background-color: #256fc9;
}

QPushButton:disabled {
    background-color: #ccd7e8;
    color: #8d9ab0;
}

/* Secondary button */
QPushButton#btn_secondary {
    background-color: #eff4fc;
    color: #2f79d6;
    border: 1px solid #c8d5e9;
    margin: 8px;
    padding: 9px;
    font-size: 12px;
}

QPushButton#btn_secondary:hover {
    background-color: #e3edf9;
    border-color: #8fb4e4;
}

QPushButton#theme_toggle {
    background-color: #dde9f8;
    color: #1f4779;
    border: 1px solid #b5c8e4;
    margin: 0 8px 8px 8px;
    padding: 9px;
    font-size: 12px;
}

QPushButton#theme_toggle:hover {
    background-color: #cfdef2;
    border-color: #7ea6d8;
}

QPushButton[compact="true"] {
    min-height: 16px;
}

/* Danger button */
QPushButton#btn_danger {
    background-color: #fbe5e5;
    color: #cb3e3e;
    border: 1px solid #efc8c8;
}

QPushButton#btn_danger:hover {
    background-color: #f7dcdc;
}

/* ── Result / Output Box ── */
#result_box {
    background-color: #f7faff;
    border: 1px solid #d3deef;
    border-left: 3px solid #4d93e6;
    border-radius: 8px;
    padding: 14px;
    color: #2a4970;
    font-family: "Consolas", "Courier New", monospace;
    font-size: 12px;
}

/* ── Chat ── */
#chat_log {
    background-color: #ffffff;
    border: 1px solid #d3ddef;
    border-radius: 10px;
    padding: 14px;
}

#chat_bubble_user {
    background-color: #eaf2ff;
    border-radius: 8px;
    padding: 10px 14px;
    color: #2f5e9a;
    margin: 4px 0;
}

#chat_bubble_ai {
    background-color: #e9f7f1;
    border-radius: 8px;
    padding: 10px 14px;
    color: #1e7b53;
    margin: 4px 0;
}

/* ── KPI Cards ── */
#kpi_card {
    background-color: #ffffff;
    border: 1px solid #d5deec;
    border-radius: 12px;
    padding: 20px;
    min-width: 180px;
}

#kpi_value {
    font-size: 26px;
    font-weight: bold;
    color: #2f79d6;
}

#kpi_value[trend="up"] {
    color: #21895d;
}

#kpi_value[trend="down"] {
    color: #cb3e3e;
}

#kpi_title {
    font-size: 12px;
    color: #4e6077;
    margin-top: 4px;
}

#kpi_desc {
    font-size: 11px;
    color: #6d7f95;
    margin-top: 6px;
}

/* ── Combo Box ── */
QComboBox {
    background-color: #ffffff;
    border: 1px solid #cfd9ea;
    border-radius: 8px;
    padding: 7px 12px;
    color: #213048;
    min-width: 140px;
}

QComboBox:focus {
    border-color: #4d93e6;
}

QComboBox::drop-down {
    border: none;
    padding-right: 10px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #cfd9ea;
    selection-background-color: #e4eefb;
    color: #213048;
}

/* ── Scrollbar ── */
QScrollBar:vertical {
    background: #edf2fa;
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background: #becbe0;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #5f9ee5;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background: #edf2fa;
    height: 8px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal {
    background: #becbe0;
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background: #5f9ee5;
}

/* ── Table Widget ── */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #d5deec;
    border-radius: 8px;
    gridline-color: #d7e0ee;
    color: #213048;
}

QTableWidget::item {
    padding: 6px 10px;
}

QTableWidget::item:selected {
    background-color: #e6effb;
    color: #215084;
}

QHeaderView::section {
    background-color: #f2f6fc;
    color: #4e6077;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid #d5deec;
    font-size: 12px;
    font-weight: bold;
}

/* ── Progress Bar ── */
QProgressBar {
    background-color: #edf3fb;
    border: 1px solid #d3dded;
    border-radius: 6px;
    height: 6px;
    text-align: center;
    color: transparent;
}

QProgressBar::chunk {
    background-color: #4d93e6;
    border-radius: 6px;
}

/* ── Separator ── */
QFrame[frameShape="4"],
QFrame[frameShape="5"] {
    color: #d5deec;
    background-color: #d5deec;
    border: none;
    max-height: 1px;
}

QFrame#divider {
    color: #d5deec;
    background-color: #d5deec;
    border: none;
    max-height: 1px;
}

/* ── Tooltip ── */
QToolTip {
    background-color: #ffffff;
    color: #213048;
    border: 1px solid #cfd9ea;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 12px;
}

/* ── Status Bar ── */
QStatusBar {
    background-color: #f1f5fc;
    border-top: 1px solid #d6dfec;
    color: #6d7f95;
    font-size: 11px;
    padding: 4px 12px;
}

/* ── Upload Drop Zone ── */
#drop_zone {
    background-color: #ffffff;
    border: 2px dashed #cad7ea;
    border-radius: 12px;
    padding: 40px;
}

#drop_zone:hover {
    border-color: #5f9ee5;
    background-color: #f2f7ff;
}

#drop_zone QLabel {
    color: #6d7f95;
    font-size: 14px;
}
